{
    "name": "pdf-chat-rag/pdf-chat-rag",
    "description": "WordPress plugin to chat with PDFs using RAG architecture",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "smalot/pdfparser": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "PDFChatRAG\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
